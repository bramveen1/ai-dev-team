# Authentication for Claude Code CLI
# Option A: API key (portable, works everywhere)
#   ANTHROPIC_API_KEY=sk-ant-api03-...
# Option B: Max subscription (interactive, one-time setup per machine)
#   After `docker compose up`, run: docker exec -it lisa claude auth login --claudeai
#   Credentials persist in the lisa-claude-config Docker volume.

# Slack integration (required for router)
LISA_BOT_TOKEN=xoxb-...
LISA_APP_TOKEN=xapp-...
LISA_SIGNING_SECRET=...
